{
  "name": "@datametis/convex-snowflake-connector",
  "version": "1.0.1",
  "type": "module",
  "description": "CLI and library for full-refresh syncing Convex deployments into Snowflake",
  "author": "Convex Snowflake Connector",
  "license": "MIT",
  "bin": {
    "convex-snowflake-connector": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun scripts/quality-gates.js && tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "quality-gates": "bun scripts/quality-gates.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "bun run build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "convex": "^1.39.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "snowflake-sdk": "^2.4.2",
    "yaml": "^2.9.0",
    "yauzl-promise": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/snowflake-sdk": "^1.6.24",
    "@types/yauzl": "^2.10.3",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.18.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.14.0",
    "lefthook": "^1.10.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8",
    "yazl": "^3.3.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.5",
  "keywords": [
    "convex",
    "snowflake",
    "sync",
    "cli"
  ]
}
